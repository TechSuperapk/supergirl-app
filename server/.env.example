# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=*

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/supergirl_journal?retryWrites=true&w=majority

# JWT session tokens issued by THIS backend after verifying a Firebase ID token
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=30d

# Firebase Admin SDK — used only to verify ID tokens sent by the app after
# Firebase Phone-OTP sign-in. Get this from Firebase Console > Project
# Settings > Service Accounts > Generate new private key.
# Paste the ENTIRE JSON file contents as a single-line string here (the
# escaped \n in private_key is fine — firebaseAdmin.ts un-escapes it).
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"super-bae", ...}

# Alternative to the block above: point to a JSON file on disk instead of
# inlining it. If both are set, FIREBASE_SERVICE_ACCOUNT_JSON wins.
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
