{
  "cli": { "version": ">= 7.0.0", "appVersionSource": "local" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": { "simulator": true },
      "android": { "buildType": "apk" },
      "env": { "EXPO_PUBLIC_API_BASE_URL": "https://REPLACE-WITH-YOUR-RENDER-URL.onrender.com/api" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": { "buildType": "apk" },
      "env": { "EXPO_PUBLIC_API_BASE_URL": "https://REPLACE-WITH-YOUR-RENDER-URL.onrender.com/api" }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": { "buildType": "app-bundle" },
      "env": { "EXPO_PUBLIC_API_BASE_URL": "https://REPLACE-WITH-YOUR-RENDER-URL.onrender.com/api" }
    }
  }
}
